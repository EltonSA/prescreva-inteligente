generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum SexType {
  MASCULINO
  FEMININO
  OUTRO
}

enum AIProvider {
  OPENAI
  GEMINI
  CLAUDE
}

enum FeedbackCategory {
  SUGESTAO
  BUG
  OUTRO
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  DONE
  DISMISSED
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  phone      String?
  profession String?
  avatar     String?
  role       Role     @default(USER)
  isActive   Boolean  @default(true)
  lastLogin  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patients         Patient[]
  formulas         Formula[]
  formulaAiVersions FormulaAiVersion[]
  conversations    Conversation[]
  feedbackTickets         FeedbackTicket[]
  feedbackTicketMessages  FeedbackTicketMessage[]
  aiUsageLogs             AiUsageLog[]

  @@map("users")
}

model Patient {
  id                    String   @id @default(uuid())
  name                  String
  age                   Int
  sex                   SexType
  skinType              String?
  phototype             String?
  treatmentGoal         String?
  additionalInfo        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  formulas Formula[]
  conversations Conversation[]

  @@map("patients")
}

enum AtivoUsageGroup {
  EXTERNO
  INTERNO
  AMBOS
}

model AtivoUsageItem {
  id        String          @id @default(uuid())
  group     AtivoUsageGroup
  name      String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  ativos Ativo[]

  @@unique([group, name])
  @@index([group, sortOrder])
  @@map("ativo_usage_items")
}

model Ativo {
  id                String   @id @default(uuid())
  name              String
  description       String?
  filePath          String?
  fileName          String?
  usageType         String?  // legado / texto livre da IA (opcional)
  usageTypeItemId   String?
  usageTypeItem     AtivoUsageItem? @relation(fields: [usageTypeItemId], references: [id], onDelete: SetNull)
  /// Escopo no ativo: EXTERNO/INTERNO ou AMBOS (item do catálogo continua sendo só externo ou interno)
  usageScope        AtivoUsageGroup?
  compatibleForms   String?  // Creme, Gel, Sérum, Loção, Cápsula (comma-separated)
  category          String?  // legado (não usado na UI; pode ser removido em migração futura)
  concentrationMin  String?  // e.g. "0.5%"
  concentrationMax  String?  // e.g. "5%"
  contraindications String?  // Texto livre: gestantes, pele sensível, etc.
  technicalNotes    String?  // pH ideal, incompatibilidades, fotossensibilidade
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  embeddings Embedding[]

  @@index([usageTypeItemId])
  @@map("ativos")
}

model Formula {
  id          String   @id @default(uuid())
  title       String
  content     String
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("formulas")
}

model AiSettings {
  id           String     @id @default(uuid())
  systemPrompt String     @default("Você é um assistente farmacêutico especializado em prescrições magistrais.")
  provider     AIProvider @default(OPENAI)
  apiKey       String?
  model        String     @default("gpt-4o-mini")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("ai_settings")
}

enum AiUsageSource {
  CHAT
  PDF_ANALYSIS
  FORMULA_AI
}

/// Registro de tokens retornados pela API (OpenAI) para estimar custo no mês.
model AiUsageLog {
  id               String         @id @default(uuid())
  provider         AIProvider
  source           AiUsageSource
  model            String
  promptTokens     Int            @default(0)
  completionTokens Int            @default(0)
  userId           String?
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())

  @@index([provider, createdAt])
  @@index([userId, createdAt])
  @@map("ai_usage_logs")
}

model Embedding {
  id        String   @id @default(uuid())
  content   String
  embedding Float[]
  ativoId   String
  ativo     Ativo    @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("embeddings")
}

model FormulaGroup {
  id          String   @id @default(uuid())
  name        String
  description String
  iconKey     String   @default("beaker")
  isDefault   Boolean  @default(false)
  isSystem    Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags     FormulaGroupTag[]
  formulas LibraryFormula[]

  @@map("formula_groups")
}

model FormulaGroupTag {
  id      String @id @default(uuid())
  groupId String
  tagName String

  group FormulaGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("formula_group_tags")
}

model LibraryFormula {
  id           String   @id @default(uuid())
  groupId      String
  name         String
  composition  String
  instructions String
  /// Quantos dias após o cadastro a fórmula aparece em "Novidades" (padrão 7)
  noveltyDays  Int      @default(7)
  createdBy    String?
  isOfficial   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group      FormulaGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  aiVersions FormulaAiVersion[]
  tags       LibraryFormulaTag[]

  @@map("library_formulas")
}

model LibraryFormulaTag {
  id               String @id @default(uuid())
  libraryFormulaId String
  tagName          String

  formula LibraryFormula @relation(fields: [libraryFormulaId], references: [id], onDelete: Cascade)

  @@map("library_formula_tags")
}

model FormulaAiVersion {
  id                          String   @id @default(uuid())
  userId                      String
  baseFormulaId               String
  title                       String
  originalFormulaSnapshot     String
  originalInstructionsSnapshot String
  userRequest                 String
  aiResultFormula             String
  aiResultInstructions        String
  isFavorited                 Boolean  @default(false)
  createdAt                   DateTime @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseFormula LibraryFormula @relation(fields: [baseFormulaId], references: [id], onDelete: Cascade)

  @@map("formula_ai_versions")
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  patientId String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient  Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@map("conversations")
}

model ConversationMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String
  referencedAtivos Json?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_messages")
}

model FeedbackTicket {
  id        String           @id @default(uuid())
  title     String
  message   String
  category  FeedbackCategory @default(SUGESTAO)
  status    FeedbackStatus   @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages FeedbackTicketMessage[]

  @@index([userId])
  @@index([status])
  @@map("feedback_tickets")
}

model FeedbackTicketMessage {
  id        String   @id @default(uuid())
  body      String
  createdAt DateTime @default(now())

  ticketId String
  ticket   FeedbackTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("feedback_ticket_messages")
}
