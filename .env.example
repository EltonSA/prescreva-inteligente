# ============================================
# PRESCREVA INTELIGENTE - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env com valores reais!

# Ambiente: development | production
NODE_ENV=development

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prescrevadb
DB_USER=postgres
DB_PASSWORD=root
DATABASE_URL=postgresql://postgres:root@localhost:5432/prescrevadb

# ---- JWT ----
# OBRIGATÓRIO em produção: use uma chave forte (ex: openssl rand -hex 32)
JWT_SECRET=sua-chave-secreta-aqui-mude-em-producao
JWT_EXPIRES_IN=7d

# ---- AI Providers (configure pelo painel admin) ----
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# ---- Bubble Sync (opcional) ----
BUBBLE_BASE_URL=https://prescrevainteligente.com.br/api/1.1/obj
BUBBLE_DATA_TYPE=Formula
BUBBLE_API_TOKEN=
DOWNLOAD_DIR=pdfs_ativos

# ---- App ----
API_PORT=3333
# Em produção: domínio(s) permitido(s), separados por vírgula
CORS_ORIGIN=http://localhost:3000
# URL da API acessível pelo navegador
NEXT_PUBLIC_API_URL=http://localhost:3333
